{
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/training",
      "destination": "/api/training"
    },
    {
      "source": "/suggest-replies",
      "destination": "/api/suggest-replies"
    }
  ]
}
